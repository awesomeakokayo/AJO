# Local dev default — each developer can use their own SQLite file.
# Point this at the Render Postgres connection string for the shared/staging env.
DATABASE_URL=sqlite:///./ajo.db

# Must be identical between local dev and the shared Render deployment —
# this is the entire interop contract between the two devs' routers.
JWT_SECRET=replace-with-a-long-random-string

# Comma-separated phone numbers auto-promoted to is_admin on signup.
ADMIN_PHONES=08010000001

# Optional — falls back to a deterministic template if unset, so the app
# (and the demo) still works with no Groq key configured.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ALATPay sandbox — stubbed in app/services/alatpay_service.py until wired up
ALATPAY_API_KEY=
ALATPAY_BASE_URL=https://sandbox.alatpay.ng/api

# Nomba Payments (sandbox) — set real values in Render dashboard & local .env
# See §3 of the Nomba integration docs for where to find each value.
NOMBA_BASE_URL=https://api.nomba.com
NOMBA_ACCOUNT_ID=
NOMBA_SUBACCOUNT_ID=
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_WEBHOOK_SIGNATURE_KEY=
